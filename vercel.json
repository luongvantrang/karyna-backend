{
  "version": 2,
  "functions": {
    "api/create.js": { "memory": 128, "maxDuration": 10 },
    "api/get.js": { "memory": 128, "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/create", "dest": "/api/create.js" },
    { "src": "/api/get", "dest": "/api/get.js" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
