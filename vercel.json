{
  "version": 2,
  "functions": {
    "api/create.js": { "memory": 128, "maxDuration": 10 },
    "api/get.js": { "memory": 128, "maxDuration": 10 },
    "api/login.js": { "memory": 256, "maxDuration": 30 },
    "api/refresh-proxy.js": { "memory": 256, "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/login", "destination": "/api/login" },
    { "source": "/", "destination": "/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/refresh-proxy",
      "schedule": "0 */2 * * *"
    }
  ]
}
